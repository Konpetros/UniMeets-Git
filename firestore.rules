rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Profiles rules
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().username is string 
        && incoming().username.size() >= 3 
        && incoming().username.size() <= 20
        && incoming().university is string 
        && incoming().university.size() > 0
        && incoming().onboarding_completed == true;
      allow update: if isOwner(userId)
        && incoming().username is string 
        && incoming().username.size() >= 3 
        && incoming().username.size() <= 20
        && incoming().university is string 
        && incoming().university.size() > 0;
    }

    // UniMeets rules
    match /unimeets/{unimeetId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() 
        && isValidId(unimeetId)
        && incoming().title is string 
        && incoming().title.size() > 0 
        && incoming().title.size() <= 60
        && incoming().category is string
        && incoming().creator_id == request.auth.uid
        && incoming().status == 'active'
        && incoming().participant_ids is list;

      allow update: if isSignedIn()
        && (
          // Action 1: Creator updating or expiring/cancelling the meetup
          (existing().creator_id == request.auth.uid && incoming().creator_id == request.auth.uid)
          ||
          // Action 2: Student joining/requesting the meetup (only allowed to update participant_ids/pending_ids list)
          (
            existing().status == 'active'
            && (
              incoming().diff(existing()).affectedKeys().hasOnly(['participant_ids']) ||
              incoming().diff(existing()).affectedKeys().hasOnly(['pending_ids']) ||
              incoming().diff(existing()).affectedKeys().hasOnly(['participant_ids', 'pending_ids'])
            )
            && (!incoming().keys().hasAll(['participant_ids']) || incoming().participant_ids.size() <= 50)
            && (!incoming().keys().hasAll(['pending_ids']) || incoming().pending_ids.size() <= 50)
          )
        );

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/unimeets/$(unimeetId)).data.creator_id == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/unimeets/$(unimeetId)).data.participant_ids
        );
        
        allow write: if isSignedIn() 
          && incoming().sender_id == request.auth.uid
          && incoming().text is string 
          && incoming().text.size() <= 500
          && (
            get(/databases/$(database)/documents/unimeets/$(unimeetId)).data.creator_id == request.auth.uid ||
            request.auth.uid in get(/databases/$(database)/documents/unimeets/$(unimeetId)).data.participant_ids
          );
      }
    }

    // Blocks rules
    match /blocks/{blockId} {
      allow read: if isSignedIn() && (resource == null || resource.data.blocker_id == request.auth.uid);
      allow create: if isSignedIn() && incoming().blocker_id == request.auth.uid;
      allow delete: if isSignedIn() && existing().blocker_id == request.auth.uid;
    }

    // Reports rules
    match /reports/{reportId} {
      allow read: if isSignedIn() && existing().reporter_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().reporter_id == request.auth.uid;
    }
  }
}
